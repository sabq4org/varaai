# VARA web — copy to .env.local and adjust.
# Base URL of the VARA Edge API the site reads from.
# dev:  http://localhost:8787  (run `cd server && bun run dev`)
# prod: the deployed Railway URL of VARA Edge.
VARA_EDGE_URL=http://localhost:8787

# Public site origin — used for sitemap, canonical URLs and Open Graph.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
